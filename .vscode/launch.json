      "name": "Goreman: Attach Server",
      "type": "go",
      "request": "launch",
      "mode": "exec",
      "debugAdapter": "dlv-dap",
      "outputMode": "remote",
      "port": 2345,
      "host": "127.0.0.1",
      "program": "${workspaceFolder}/dist/armada-server",
      "args": ["--config", "${workspaceFolder}/_local/server/config.yaml"],
      "cwd": "${workspaceFolder}"
